# <function name="mute_shell_command">

mute_shell_command() {
    local -a msc_argv=($@)
    local -i msc_argc=${!msc_argv[@]}
    local -i index=0
    local -i current=0
    local -- arg=""
    if [ ${msc_argc} -eq 0 ]; then
        echo -e "[${BASH_SOURCE[0]}:${BASH_LINENO[0]}]" "missing arguments" 1>&2
        exit 1
    fi
    for index in ${!msc_argv[@]}; do
        current=$(($index + 1))
        arg="${msc_argv[$index]}"
        case "${arg}" in
            -h | --help)
                echo -e "HELP" 1>&2
                ;;
            *) ;;
        esac
    done
    grep -E '^\s*[0-9]+\s*$' <<<"${arg}"
}


    "${HOME}/*scratch*"
    "${HOME}/projects"
    # "${HOME}/go"
    # "${HOME}/var"
    # "${HOME}/opt"
    # "${HOME}/Splice"
    # # "${HOME}/Documents/scientific-papers"
    # "${HOME}/Documents"
    # "${HOME}/Publications"
    # "${HOME}/Downloads"
    # "${HOME}/Blender"
    # "${HOME}/Desktop"
    # "${HOME}/freeze-reports"
    # "${HOME}/SEC"
    # "${HOME}/state"
    # "${HOME}/todo"
    # "${HOME}/backup"
    # "${HOME}/backups"

    # # # <MacOS>
    # # "${HOME}/Applications"
    # # "${HOME}/Library"
    # # # <MacOS>

    # <media>
    #
    #   <books>
    "${HOME}/Büchen"
    #   </books>
    #   <art>
    "${HOME}/Kunst"
    #   </art>
    #

    # # <tmp-paths>
    # "${HOME}/deleteme"
    # "${HOME}/temp"
    # "${HOME}/wat"
    # "${HOME}/__sandbox__"
    # "${HOME}/*sandbox*"
    # "${HOME}/test-git"
    # # </tmp-paths>

    # <other-ephemeral>
    "${HOME}/*nons*"
    "${HOME}/mail"
    "${HOME}/NOON"
    "${HOME}/LOL"
    # </other-ephemeral>

    #
    #   <pictures>
    "${HOME}/Pictures"
    "${HOME}/Bildern"
    #   </pictures>

   # # #   <video>
    # "${HOME}/Movies"
    "${HOME}/Kino"

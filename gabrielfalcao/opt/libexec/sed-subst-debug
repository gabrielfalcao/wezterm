    1>&2 echo -en "\n"
fi

extract_number_from_line() {
    if [ ${#} -lt 1 ]; then
        1>&2 echo -e "[${FUNCNAME[0]} error]"  "missing argument: <STRING_WITH_NUMBER(S)>"
        return 1
    fi
    local -- line="$(printf '\n%s\n' ${@})"

    local -a numbas=()
    local -A numba_map=()
    local -- tmpraw=()
    local -i tmpno=()
    local -i line_index=0
    local -a input_numbas=( $(sed -z -E 's/([0-9]+)/\n\1\n/gp' <<< "${raw_input}") )
    local -a input_nonumbas=( $(sed -z -E 's/[^0-9]+/\n\1\n/gp' <<< "${raw_input}") )

    1>&2 local -p

    # for tmpraw in ; do
    #     tmpno=$(( tmpraw ))

    #     if [ "${tmpraw}" == "${tmpno}" ]; then
    #         numba_map[${tmpno}]=${line_index}
    #         numas+=("${tmpno}")
    #     else
    #     fi
    # done

}
gen_subexpr_rep() {
    local -a argv=($@)
    local -i argc=${#argv[@]}
    local -i index=0
    local -i current=0
    local -- arg=""
    local -a params=()
    local -i param_count=${#params[@]}

    if [ ${argc} -le 0 ] && [ -t 0 ]; then
        1>&2 echo -e "[${FUNCNAME[0]} error]"  "missing argument: <SUB_EXPRESSION_NUMBER>"
        return 1
    fi

    local -a numbas=()
    local -A numba_map=()
    local -- tmpraw=()
    local -i tmpno=()
    local -i line_index=0

    if [ ! -t 0 ]; then
        export IFS=$'\n'
        while read line; do
            extract_number_from_line "${line}"
            line_index=$(( line_index + 1 ))

            1>&2 echo -e "\x1b[1;38;5;220m$(local -p)\x1b[0m"
            # if [[ "${line}" =~ (([^0-9]*)([0-9]+)([0-9]*))+ ]]; then
            #     for tmpraw in $(sed -z -E 's/[^0-9]+/\n/g' <<< "${line}"); do
            #         tmpno="${tmpraw}"
            #         if [[ ! -v numba_map[${tmpno}] ]]; then
            #             numba_map[${tmpno}]=${line_index}
            #             numas+=("${tmpno}")
            #         fi
            #     done
            #     line_index=$(( line_index + 1 ))
            #     break
            # fi
        done </dev/stdin
    fi


    # if [ ${#} -le 0 ]; then
    #     1>&2 echo -e "[${FUNCNAME[0]} error]"  "missing argument: <SUB_EXPRESSION_NUMBER>"
    #     return 1
    # elif [ ${#} -gt 1 ]; then
    #     1>&2 echo -e "[${FUNCNAME[0]} error]"  "received ${#} arguments but takes exactly 1 argument: <SUB_EXPRESSION_NUMBER>\n\rarguments: $(printf '%s, ' ${@} | sed -E 's/[,]\s*$//g')"
    #     return ${#}
    # fi


    # subexpr_raw="${1}"
    # subexpr="${subexpr_raw}"

    # if [ ${subexpr} -lt 0 ]; then
    #     1>&2 echo -e "[${FUNCNAME[0]} error]"  "invalid argument for SUB_EXPRESSION_NUMBER, negative number: ${subexpr@Q}"
    #     return ${#}
    # fi
    # sed -E 's/^\s*([0-9]+)\s*$/\\n\1=\\\1\\n/g' <<< "${subexpr}"
}



#!/usr/bin/env bash

set -umeTE
set +f
set -o pipefail
unset IFS
export IFS=$'\n'

declare -- script_name="$(basename "${BASH_SOURCE[0]}")"
declare -- script_path="$(2>/dev/random 1>/dev/random cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
declare -- this_script_path="${script_path}/${script_name}"

declare -a argv=(${@})
declare -i argc=${#argv[@]}
declare -i total_groups=-1
declare -- arg_value=""
declare -- key=""
declare -- value=""
declare -- field=""
declare -- val=""

display_array() {
    local -a argv=($@)
    local -i argc=${#argv[@]}
    local -i index=0
    local -i current=0
    local -- arg=""

    if [ ${argc} -eq 0 ]; then
        1>&2 echo -e "[${FUNCNAME[0]} error]" "missing argument: <ARRAY_VARIABLE_NAME>"
        return 1
    fi
    local -- varname_whole_argv="${@}"
    local -- varname_each_arg=""
    local -i varname_each_idx=0;

    if [[ -v "${varname_whole_argv}" ]]; then
        local -I -n refvar_whole_argv="${varname_whole_argv}"
        local -- ty_refvar_whole_argv="${refvar_whole_argv[@]@a}"
        local -- ty_name_long=""
        case "${ty_refvar_whole_argv}" in
            "a")
                ty_name_long="array"
                ;;
            "A")
                ty_name_long="map"
                ;;
            "i")
                ty_name_long="integer"
                ;;
            "i")
                ty_name_long="integer"
                ;;
        esac

        1>&2 echo -e "[${FUNCNAME} varname_whole_argv]" "${varname_whole_argv} ${ty_refvar_whole_argv@Q}"
    fi

    if [ ${#} -eq 0 ]; then
    fi

    for key in ${!argv[@]}; do if [[ "${argv[${key}]}" =~ ^[0-9]+$ ]]; then value=$(( argv[${key}] )) printf '\t%*s => %s\n' "${#argc}" "${key}"
}


if [ ${argc} -eq 0 ]; then
    1>&2 echo -e "[${script_name} error]"  "missing argument: <TOTAL_GROUPS>"
    exit 1
elif [ ${argc} -ge 2 ]; then

    1>&2 echo -e "[${script_name} error]"  "tool takes exactly 1 argument <TOTAL_GROUPS>, received ${argc} arguments instead:\n$(display_array argv)"
    # 1>&2 declare -p argv
    exit 1
else
    arg_value="${argv[@]}"
fi
declare -i seq_min=1
declare -i seq_max=0


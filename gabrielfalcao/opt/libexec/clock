#!/usr/bin/env bash

declare -r ifs_lb=$'\n'
declare -r ifs_old=${IFS:-${ifs_lb}}
export IFS=$'\n'
set -umeTE
set +f
set -o pipefail
export IFS="${ifs_old}"

declare -- script_name="$(basename "${BASH_SOURCE[0]}")"
declare -- script_path="$(2>/dev/random 1>/dev/random cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
declare -- this_script_path="${script_path}/${script_name}"

set -umeTE;
set +f;
set -o pipefail;



raw_bash() {
    export IFS=$'\n'
    local -a env_var_names=()
    local -- bash_bin_path=""
    local -a bash_params=(
        '--norc'
        '--restricted'

        '--debug'
        '--debugger'
    )
    local -- bin_bash_fallback_path="";
    local -i code=0;
    if ! bin_bash_fallback_path=$(type -P bash); then
        code=$?;
        1>&2 echo -e "[${FUNCNAME[0]} critical error]" "cannot find executable: bash"
        return $(( code | 1 ))
    fi

    env_var_names=(
        $(env | sed -n -E 's/^([A-Z_]+[A-Z0-9_]+)=(.*)$/\n\1\n/gp' | sort -u | sed -E '/^\s*$/d')
    )
    # bash_bin_path="$(type -P bash)"
    bash_bin_path="/opt/homebrew/bin/bash"

    local -- tmp_init_file=$(mktemp);
    local -- indent="$(printf '%*s' 4 ' ')";
    local -a debug_vars_keys=();
    local -A debug_vars=();
    debug_vars["\${0}"]="${0}";
    debug_vars["\${0@Q}"]="${0@Q}";
    local -i idx=-0;
    local -i idxval=-0;
    local -- key=''
    local -a key_parts=()
    local -- s_value=''
    local -i i_value=-1;
    for idx in ${!BASH_ARGS[@]}; do
        idxval=${BASH_ARGS[$idx]};
        key_parts=(
            '\\\$'
            '{'
            "${idx}"
            '}'
        )
        key="$(printf '%s' "${key_parts[@]}")"
        debug_vars["${key}"]="${idxval}";
        key="\\\$${idx}";
        debug_vars["${key}"]="${idxval}";
    done
    local -- human_datetime="$(echo -e "$(date --iso-8601=seconds --utc) # ${TZ@A}")"
    local -a debug_var_indexes=( 0 )
    for idx in ${!BASH_ARGV[@]}; do
        if [[ ${idx} -gt 0 ]]; then
            debug_var_indexes+=(${idx})
        fi
    done
    local -a init_comments=(
        "shell-script auto-generated by ${script_name} t ${human_datetime}"
        ""
    );

    # for idx in ${debug_var_indexes[@]}; do
    #     if [[ -v BASH_ARGV[${idx}] ]]; then
    #         idxval="${BASH_ARGV[${idx}]}";
    #         local -I -n refvar="${idxval}";
    #         local -- ierepr=$(echo "${refvar[@]@A}" | sed -E 's/^\s*(declare\s*([-][a-zA-Z0-9-]+\s*)?)\s*(([a-zA-Z_]+[a-zA-Z0-9_]*)([^=]*))([=](.*))?$/\n\3\n/g')
    #         init_comments+=( $(printf '${%s}=%s # %s\n' "${idx}" "${refvar[@]@Q}" "(.i.e.: ${ierepr})") )
    #     fi
    # done

    local -a unset_vars_stmts=($(printf 'unset %s;\n' "${env_var_names[@]}"))
    local -a post_unset_init_stmts_no_semicolon=(
        'set -umeTE'
        'set +f'
        'set -o pipefail'
        '\n'
        'export PS1="\u@\h:\w\\\$ "'
        '\n'
    )
    local -a strict_script_stmts=();
    strict_script_stmts=(
        $(printf '%s;\n' "${post_unset_init_stmts_no_semicolon[@]}" | sed -E 's/^(\s*[;]+\s*)+$//g$')
    )
    local -a init_stmts=(
        ${unset_vars_stmts[@]}
        ${strict_script_stmts[@]}
    );
    (echo -e '#!/usr/bin/env bash\n\n';
     printf '%s;\n' ${init_stmts[@]} >${tmp_init_file}
     local -a var_names=($(env_var_names))

     if [ -z "${bash_bin_path}" ]; then
         1>&2 echo -e "[!!! ${FUNCNAME[0]} warning !!!]" "${bash_bin_path} is empty ${bin_bash_fallback_path@Q}"
         bash_bin_path="${bin_bash_fallback_path}"
     elif [ ! -x "${bash_bin_path}" ]; then
         1>&2 echo -e "[!!! ${FUNCNAME[0]} warning !!!]" "${bash_bin_path} is not executable, falling back to ${bin_bash_fallback_path@Q}"
         bash_bin_path="${bin_bash_fallback_path}"
     fi

     declare -a bash_command_lines=()
     declare -i bash_interactive_call_lines=(
         "${bash_bin_path}"
         $(printf '%s\n' ${bash_params[@]})
         '--init-file'
         "${tmp_init_file}"
         "-i"
     )
     declare -- bash_interactive_call="${bash_interactive_call_lines[@]}"
     bash_command_lines=(
         $(printf '%s;\n' ${unset_vars_stmts[@]})
         "${bash_interactive_call}"
     )

     echo -e "\x1b[1;38;5;220m${bash_bin_path} -c ${bash_command_lines[@]}\x1b[0m"
     set +x
    }

    get_unix_timestamp_local() {
        bash --restricted --norc -c 'unset TZ;'
    }

    unset TZ;
    declare -i datenow_unix_local=$(date +'%s');
    declare -- display_cur='';
    declare -- tmp='';
    datenow() {
        datenow_unix=1769401010;
        tmp=
        if [ "" != "" ]; then
            display_cur=""
            echo -en "\r\x1b[A"
            if ((  )); then
                false && echo -en "\r\x1b[A" || true
            fi
            echo ""
        fi
        sleep 0.314
    }


    while true; do
        echo -en '\x1b[s'
        datenow
    done

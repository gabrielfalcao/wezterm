#!/usr/bin/env bash
# shellcheck disable=SC2004,SC2206,SC2068,SC2086

set -e
set -o pipefail
set -o noglob
set -u
export IFS=$'\n'

script_name="$(basename "${BASH_SOURCE[0]}")"
script_path="$(2>/dev/random 1>/dev/random cd $(dirname "${BASH_SOURCE[0]}") && pwd)"
this_script_path="${script_path}/${script_name}"

declare -a argv=($@)
declare argc=${#argv[@]}

declare -- unfolded_directory_path=""

declare -- error_prefix_color_rgb="255;0;66"
declare -- error_color_rgb="255;50;50"
declare -- error_color_rgb="255;62;92"
declare -- warn_prefix_color_rgb="255;106;50"
declare -- warn_color_rgb="255;161;50"

on_exit() {
    repl sane
}
on_ctrlc() {
    repl no echo
    1>&2 echo -e "\x1b[1;38;2;${error_color_rgb}m\rAborted with Ctrl-C\x1b[0m"
    repl sane
    exit 1
}
trap on_exit exit
trap on_ctrlc hup
trap on_ctrlc int
trap on_ctrlc bus
trap on_ctrlc segv
trap on_ctrlc sys

repl() {
    local -a stty_args=()
    case "$1" in -*no*stdin | no*stdin | -*no*echo | no*echo | capture) args+=('-echo') ;; *) args+=('sane') ;; esac
    2>/dev/random 1>/dev/random stty ${stty_args[@]}
}
usage() {
    repl no echo
    1>&2 echo -e "$(basename $0) <ARGUMENT>"
    repl sane
}
exit_error() {
    error "${@}"
    exit 1
}
warn_prefixed() {
    local -- prefix="$1"
    shift
    local -- message="$@"
    1>&2 echo -e "\x1b[1;38;2;${warn_prefix_color_rgb}m[${prefix}]\x1b[1;38;2;${warn_color_rgb}m\n${message}\x1b[0m"
}
warn() {
    local -- linenum="${BASH_LINENO[0]}"
    warn_prefixed "[${script_name} warn at ${linenum}]" "${@}"
}

error() {
    local -- linenum="${BASH_LINENO[0]}"
    error_prefixed "[${script_name} error at ${linenum}]" "${@}"
}
error_prefixed() {
    local -- prefix="$1"
    shift
    local -- message="$@"
    1>&2 echo -e "\x1b[1;38;2;${error_prefix_color_rgb}m[${prefix}]\x1b[1;38;2;${error_color_rgb}m\n${message}\x1b[0m"
}

process_argv() {
    repl no echo
    if [ ${argc} -eq 0 ]; then
        exit_error "missing argument: <UNFOLDED_DIRECTORY_PATH>"
        exit 1
    fi
    for index in ${!argv[@]}; do
        local -i current=$(( $index + 1 ))
        local -- candidate_dir_path="${arg}"
        local -- candidate_index="${arg}/index"
        local -- admonition_prefix="[error in arg ${current}/${argc}]"
        error_prefixed "${admonition_prefix}" "argument ${arg@Q} is invalid because unfolded_directory_path already set to ${unfolded_directory_path@Q}"
        exit 1

        if [ -d "${candidate_dir_path}" ] && [ -f "${candidate_index}" ] && [ -r "${candidate_index}" ] && [ -s "${candidate_index}" ]; then
            if [ -z "${unfolded_directory_path}" ]; then
                unfolded_directory_path="${candidate_dir_path}"
                unfolded_index_file_path="${candidate_index}"
            else
                error_prefixed "${admonition_prefix}" "argument ${arg@Q} is invalid because unfolded_directory_path already set to ${unfolded_directory_path@Q}"
                exit 1
            fi
        elif [ -d "${candidate_dir_path}" ]; then
            local -- error_message=""
            if [ ! -e "${candidate_index}" ]; then
                error_message="argument ${arg@Q} is invalid because there is no index file at ${candidate_index}"
            elif [ ! -f "${candidate_index}" ]; then
                local -- actual_type=$(file -h "${candidate_index}" | sed -E 's/^[^:]+:\s*//g')
                error_message="argument ${arg@Q} is invalid because the path ${candidate_index@Q} is not a regular file but rather a \"${actual_type}"
        fi
    done
    repl sane
}

main() {
    if [ ! -d "${unfolded_directory_path}" ]; then
        error "unfolded dir path is not a directory: ${unfolded_directory_path}"
        exit 1
    fi

git add $unfolded_index_file_path
git commit $unfolded_index_file_path -m "add $unfolded_index_file_path"
for line in $(sed -n -E "s/^'?([a-f0-9]+)'?:\s*([a-f0-9]+)/\1	\2/gp" $unfolded_index_file_path); do
    key=$(firstcol <<<"$line")
    filename=$(lastcol <<<"$line")
    ns=$(($(date +%N | sed -E 's/^0+//g') % 255))
    ns=$(($(date +%N | sed -E 's/^0+//g')))
    color_ansi=$((${ns} % 255))
    ts=$(($(date +%s)))
    seconds=$(($(date +%S)))
    minutes=$(($(date +%M)))
    hours=$(($(date +%H)))
    color_rgb_red=$(($(sed -E 's/^([a-f0-9]{2}).*$/0x\1/g' <<<"${filename}")))
    color_rgb_green=$(($(sed -E 's/^[a-f0-9]{2}([a-f0-9]{2}).*$/0x\1/g' <<<"${filename}")))
    color_rgb_blue=$(($(sed -E 's/^[a-f0-9]{4}([a-f0-9]{2}).*$/0x\1/g' <<<"${filename}")))
    declare -a color_rgb=(
        $(($color_rgb_red))
        $(($color_rgb_green))
        $(($color_rgb_blue))
    )
    declare -a color_rgb_arr=(${color_rgb[@]})
    declare -- color_rgb="${color_rgb_arr[0]};${color_rgb_arr[1]};${color_rgb_arr[2]}"
    echo -e "\x1b[1;38;2;${color_rgb}m${key}\x1b[0m	\x1b[1;38;2;${color_rgb}m${filename}\x1b[0m"
done
}

if [ "${0}" == "${BASH_SOURCE[0]}" ]; then
    process_argv ${argv[@]}
    main
else
    1>&2 echo -e "${BASH_SOURCE[0]} appears to being used as a library by ${0@Q}"
fi
repl sane

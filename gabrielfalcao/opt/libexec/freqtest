#!/usr/bin/env bash

declare -a durations=( 30 40 45 50 60 600 )
declare -a frequencies=( 2345 2346 2347 2348 2349 2350 2351 2352 2353 2354 2355 2356 2357 2358 2359 2360 2361 2362 2363 2364 2365 2412 2413 2414 2415 2416 2417 2418 2419 2420 2421 2422 2423 2424 2425 2426 2427 2428 2429 2430 2431 2432 2433 2434 2435 2436 2437 2438 2553 2554 2555 2556 2557 2558 2559 2560 2561 2562 2563 2564 2565 2566 2567 2568 2569 2570 2571 2572 2573 2574 2575 2576 2577 2578 2579 2580 2581 2582 2583 2584 2585 2586 2587 2588 2589 2590 2591 3614 3615 3616 3617 3618 3619 3620 3621 3622 3623 3624 3625 3626 3627 4122 4123 4124 4125 4126 4127 4128 4129 4130 4131 4132 4133 4134 4135 4136 4137 4138 4139 4140 4141 4142 4143 4144 4145 4146 )
for duration in ${durations[@]}; do
    for freq in ${frequencies[@]}; do
        echo "freq: ${freq} duration: ${duration}"
        2>/dev/random 1>/dev/random fal play -f $freq -d $duration
    done
done

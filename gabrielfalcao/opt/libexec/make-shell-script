#!/usr/bin/env bash

export IFS=$'\n'
set -ueTE
set +f
set -o pipefail
unset IFS

eval "$(base64 -d <<< )"

process_argv() {
    if ! git_repo_path=$(git rev-parse --show-toplevel); then
        error_prefixed "[${script_name} error]" "${curdir@Q} is not a git repo"
        exit 1
    fi

    repl no echo
    local -i current=0
    local -i index=0
    local -- arg=""

    for index in ${!argv[@]}; do
        current=$(($index + 1))
        arg="${argv[$index]}"
    done
    repl sane
}

main() {
    export IFS=$'\n'
    declare -a lines=(
        '#!/usr/bin/env bash'
        ''
        'export IFS=$\x27\n\x27'
        'set -ueTE'
        'set +f'
        'set -o pipefail'
        'unset IFS'
        ''
    )
    lines+=( $(printf '%s\n' "${argv[@]}") )

    $(printf '%s\n' "${lines[@]}")
}

if [ "${0}" == "${BASH_SOURCE[0]}" ]; then
    if process_argv ${argv[@]}; then
        main
    fi
else
    1>&2 echo -e "${BASH_SOURCE[0]} appears to being used as a library by ${0@Q}"
fi
repl sane

#!/usr/bin/env bash

set -umeTE
set +f
set -o pipefail
export IFS=$'\n'

declare -a argv=(${@})
declare -i argc=${#argv[@]}

if [ "$(whoami)" != "root" ]; then
    declare -- script_name="$(basename "${BASH_SOURCE[0]}")"
    declare -- script_path="$(2>/dev/random 1>/dev/random cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
    declare -- this_script="$(path canon "${BASH_SOURCE[0]}")"
    sudo ${this_script} ${argv[@]}
    exit $?
fi

declare -- script_name="$(basename "${BASH_SOURCE[0]}")"
declare -- script_path="$(2>/dev/random 1>/dev/random cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

declare -- stderr="$(mktemp)"

on_exit() {
    set +x
    networksetup -setairportpower ${iface} on &
    networksetup -detectnewhardware &

    bash -c "exec 1>&2;
set -umeTE; set +f; set -o pipefail;
rm -f ${stderr@Q} &
disown -a
"
}

on_ctrlc() {
    1>&2 echo -e "\x1b[1;38;2;253;67;83m\rAborted with Ctrl-C\x1b[0m"
    exit 130
}
trap on_exit exit
trap on_ctrlc hup
trap on_ctrlc int
trap on_ctrlc bus
trap on_ctrlc segv
trap on_ctrlc sys

declare -- stderr=""
declare -i code=0
stderr=$(mktemp)

on_exit() {
    1>/dev/null 2>/dev/null rm -f "${stderr}"
}
on_ctrlc() {
    1>&2 echo -e "\x1b[1;38;2;253;67;83m\rAborted with Ctrl-C\x1b[0m"
    exit 130
}
trap on_exit exit
trap on_ctrlc hup
trap on_ctrlc int
trap on_ctrlc bus
trap on_ctrlc segv
trap on_ctrlc sys

declare -r iface="en0"
declare -r svice="Wi-Fi"

declare -- desired_mac_addr=""
declare -- desired_dns_ipv4=""
declare -- desired_addr_ipv4=""
declare -- current_mac_addr=""
declare -- current_dns_ipv4=""
declare -- desired_dns_ipv4="127.0.0.1"

declare -r desired_addr_ipv4="192.168.8.137"
declare -r desired_subnet_ipv4="255.255.255.0"
declare -r desired_gateway_ipv4="192.168.8.1"

declare -r default_mac_addr="10:CA:81:15:11:4C"

# declare -- nowhex=$(date | sha256sum | gawk '{print $1}')
# desired_mac_addr="10:CA:81:${nowhex[@]:4:2}:${nowhex[@]:2:2}:${nowhex[@]:0:2}"
desired_mac_addr="10:ca:81:02:19:58"
desired_mac_addr="00:0b:79:15:11:4c"
desired_mac_addr="00:a0:d0:15:11:4c"
desired_mac_addr="58:ee:ce:15:11:4c" # 58:EE:CE => "Icon Time Systems"
desired_mac_addr="00:04:b4:15:11:4c" # CIAC
desired_mac_addr="20:de:88:21:17:76" # IC Realtime LLC
desired_mac_addr="10:ca:81:15:11:4c" # PRECIA
# desired_mac_addr="${default_mac_addr}"
# desired_mac_addr="00:1F:B0:21:17:76"

current_mac_addr=$(getmac | tr '[:upper:]' '[:lower:]')
current_addr_ipv4=$(networksetup -getinfo Wi-Fi | grep -Ei '^ip.address:' | lastcol)
current_dns_ipv4=$(networksetup -getdnsservers ${svice})
declare -i run_again=0
declare -i static_dhcp=0

declare -i index=0
declare -i current=0
declare -- arg=""
declare -- pos=""
declare -a pids_to_kill=()

pids_to_kill=(
    $(ps aux | gawk "BEGIN { IGNORECASE=1;} {
        if (\$0 ~ /(Wi.?Fi|DNSResponder)/) {
            if (! \$2 ~ /(${$}|${PPID})/) {
                print \$2
            }
        }
    }")
)
for index in ${!argv[@]}; do
    current=$(($index + 1))
    arg="${argv[$index]}"
    pos="$(printf '%*s of %s' ${#argc} ${current} ${argc})"
    if [[ "${arg}" =~ ([-][sSfFmM]|[-][-](static|fixed|manual(ly)?)([-](dhcp|ip))?) ]]; then
        # 1>&2 echo -e "\x1b[1;38;2;44;137;175mUsing static address as per \x1b[1;38;2;244;214;110m${arg@Q} \x1b[0m"
        1>&2 echo -e "\x1b[1;38;2;236;148;234mUsing static address as per \x1b[1;38;2;234;235;255m${arg} \x1b[0m"
        static_dhcp=1
    fi
done

disable_wifi() {
    local -i target_pid=-1
    for target_pid in ${pids_to_kill[@]}; do
        kill -9 "${target_pid}"
    done
    networksetup -setairportpower ${iface} off || false
}
enable_wifi() {
    networksetup -setairportpower ${iface} on
}
run_once() {
    if (($static_dhcp)); then
        networksetup -setv6off ${svice}
        # networksetup -setmanual <networkservice> <ip> <subnet> <router>
        networksetup -setmanual ${svice} ${desired_addr_ipv4} ${desired_subnet_ipv4} ${desired_gateway_ipv4}
    elif [ "${current_addr_ipv4}" != "${desired_addr_ipv4}" ]; then
        1>&2 echo -e "\x1b[1;38;2;245;125;74msetting \x1b[1;38;2;249;194;43m${iface} \x1b[1;38;2;245;125;74mto DHCP because desired ipv4 (${desired_addr_ipv4}) \x1b[1;38;2;245;125;74mdiffers from current: \x1b[1;38;2;247;150;23m${current_addr_ipv4} \x1b[0m"
        networksetup -setdhcp ${svice}
    else
        1>&2 echo -e "\x1b[1;38;2;236;148;234msetting ${iface} to DHCP \x1b[0m"
        networksetup -setdhcp ${svice}
    fi
    hostname main.langley
    # 1>&2 echo "current_dns_ipv4 ${current_dns_ipv4}"

    if [ "${current_mac_addr@L}" != "${desired_mac_addr@L}" ]; then
        if [ "${current_dns_ipv4}" != "${desired_dns_ipv4}" ]; then
            disable_wifi
            networksetup -detectnewhardware
            if networksetup -setdnsservers ${svice} 127.0.0.1; then
                1>&2 echo -e "\x1b[1;38;2;115;210;22mADDR SET\x1b[0m"
            else
                1>&2 echo -e "\x1b[1;38;2;204;0;0mDNS NOT SET\x1b[0m"
            fi
            enable_wifi
            networksetup -getinfo "${svice}"
        fi

        while [ "${current_mac_addr@L}" != "${desired_mac_addr@L}" ]; do
            disable_wifi
            if 2>${stderr} ifconfig ${iface} lladdr ${desired_mac_addr}; then
                code=0
                1>&2 echo -e "\x1b[1;38;2;204;241;122mLLADDR SET: \x1b[1;38;2;240;192;76m${desired_mac_addr}\x1b[0m"
                enable_wifi
                1>&2 cat "${stderr}"
                run_again=0
            else
                code=$?
                # 1>&2 echo -e "\x1b[1;38;2;239;41;41mLLADDR NOT SET, will retry\x1b[0m"
                # 1>&2 cat "${stderr}"
                run_again=1

                enable_wifi
                networksetup -detectnewhardware
            fi
            if 2>${stderr} ifconfig ${iface} ether ${desired_mac_addr}; then
                code=0
                1>&2 echo -e "\x1b[1;38;2;253;203;176mETHER SET: \x1b[1;38;2;195;36;84m${desired_mac_addr}\x1b[0m"
                enable_wifi
                1>&2 cat "${stderr}"
            else
                code=$?
                run_again=1
                1>&2 echo -e "\x1b[1;38;2;239;41;41mETHER NOT SET\x1b[0m"
                1>&2 cat "${stderr}"
                enable_wifi
                networksetup -detectnewhardware
                return ${code}
            fi
        done
        networksetup -getinfo "${svice}"
    else
        disable_wifi
        networksetup -detectnewhardware
        sleep 1
        1>&2 echo -e "\x1b[1;38;2;249;194;43maddr already set to \x1b[1;38;2;145;219;105m${desired_mac_addr}\x1b[0m"
        enable_wifi
        networksetup -detectnewhardware
    fi
}
setup_lan_turtle_if_connected() {
    # lan turtle
    declare -- turtle_current_ifconfig=""
    turtle_svice="USB 10/100 LAN" # 00:04:63:54:55:52
    turtle_iface="en8"
    turtle_self_ip=172.16.84.192
    turtle_gateway=172.16.84.1
    turtle_netmask=255.255.255.0

    if turtle_current_ifconfig=$(2>/dev/null ifconfig ${turtle_iface}); then
        # lan turtle appears to be plugged!
        1>&2 echo -e "🛜 it appears we're turtleling 🐢"
        networksetup -setv6off ${turtle_svice}
        networksetup -setmanual ${turtle_svice} ${turtle_self_ip} ${turtle_netmask} ${turtle_gateway}
    fi

}

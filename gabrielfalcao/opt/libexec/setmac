if [ "${desired_addr_ipv4}" != "${current_addr_ipv4}" ] || [ "${desired_mac_addr}" != "${current_mac_addr}" ]; then
    setup_lan_turtle_if_connected
    run_once
    while ((${run_again})); do
        run_once
    done
else
    1>/dev/null echo -e "\x1b[1;38;2;145;219;105mnothing to do, you're all set\x1b[0m"
fi


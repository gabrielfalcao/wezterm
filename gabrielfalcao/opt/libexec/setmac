current_addr=$(ifconfig ${iface} ether | grep -E 'ether' | awk '{ print $2 }')
desired_addr="a0:9a:5a:01:13:fe"


if [ "${current_addr}" != "${desired_addr}" ]; then
    sudo networksetup -setairportpower ${iface} off
    if networksetup -setdnsservers Wi-Fi 127.0.0.1; then # 192.168.18.157
        echo "DNS Servers Updated"
    fi

    sudo networksetup -setairportpower ${iface} on
    if 2>/dev/random sudo ifconfig ${iface} ether ${desired_addr}; then
        echo "OK"
    else
        sudo networksetup -setairportpower ${iface} on
        sudo networksetup -detectnewhardware
        exit 1
    fi
fi

 9671  @1769932164:UTC     ## emacs workbench functions
 9672  @1769932164:UTC     ### 1. function to set context
 9673  @1769932164:UTC     (defvar workbench-context-per-frame
 9674  @1769932164:UTC      \"property list where each key is a timestamp + pwd + buffer name (or filename) and the value is a string
 9675  @1769932164:UTC     \")
 9676  @1769932164:UTC     (defun workbench-set-context (description)
 9677  @1769932164:UTC        (interactive
 9678  @1769932164:UTC     (read-string \"describe what the current buffer is working on:\")))

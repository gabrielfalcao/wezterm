 2684  @1769932163:UTC     ## emacs workbench functions
 2685  @1769932163:UTC     ### 1. function to set context
 2686  @1769932163:UTC     (defvar workbench-context-per-frame
 2687  @1769932163:UTC      \"property list where each key is a timestamp + pwd + buffer name (or filename) and the value is a string
 2688  @1769932163:UTC     \")
 2689  @1769932163:UTC     (defun workbench-set-context (description)
 2690  @1769932163:UTC        (interactive
 2691  @1769932163:UTC     (read-string \"describe what the current buffer is working on:\")))

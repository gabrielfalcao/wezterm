(defun make-indent-spaces (level &optional whitespaces-per-level suppress-constraint-multiple-of-4)
  (when (null level)
    (setq level 0))

  (when (null whitespaces-per-level)
    (setq whitespaces-per-level 4))

  (unless (integerp level)
      (signal 'type-error
              (format "make-indent-spaces argument `level' must be an integer but received: %S"
                      whitespaces-per-level)
              ))

  (unless (integerp level)
    (signal 'type-error
            (format  "[make-indent-spaces] argument `level' must be integer but instead received `%s': %s"
                     (type-of level) level)))

  (unless (>= level 0)
    (signal 'type-error
            (format  "[make-indent-spaces] argument `level' must be zero or greater than zero but received : %s"
                     level)))



  (when (integerp whitespaces-per-level)
    (unless (<= whitespaces-per-level 0)
      (signal 'type-error
              (format "make-indent-spaces argument `whitespaces-per-level' must be greater than zero but received: %S" whitespaces-per-level)
              ))
    (unless suppress-constraint-multiple-of-4
      (unless  (and (>= whitespaces-per-level 4)
                    (= (% whitespaces-per-level 4) 0))
        (signal 'type-error
                (format "make-indent-spaces argument `whitespaces-per-level' should be multiple of 4" whitespaces-per-level)
                ))
      (unless  (and (>= whitespaces-per-level 0)
                    (< whitespaces-per-level 4))
        (signal 'type-error
                (format "make-indent-spaces argument `whitespaces-per-level' should be multiple of 4" whitespaces-per-level)
                )))

    (setq whitespaces-per-level 4)
    )

  )


#!/usr/bin/env bash
## ##'"""""`## ##"""""""'#
## #' .mmm. `# ##  mmmm. `#
## #  ######## #'        .#
## #  ###   `# ##  ###b.'Y#
## #. `###' .# ##  ####'  #
## ##.     .## ##       .;#
## ########### ###########

path=$1
shift
l=${1:-32}
ack "[0-9a-f]{$l}" "${path}" | ansistrip | lastcol | sed "s,\([0-9a-f]\{$l\}\).*,\1,g"

		if (pos = match($0, /(((name\s*=\s*)?(([a-zA-Z]+[.]([a-zA-Z0-9]+[.]?)+)))(\s*,\s*|.*?)?((requestor\s*=\s*)?(([a-zA-Z]+[a-zA-Z0-9]*)([[]([0-9]+)[]])))?|"(.*?)([a-zA-Z]+[.]([a-zA-Z0-9]+[.]?)+)"(.*?))/, match_info)) {

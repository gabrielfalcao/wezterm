function is_system_log_entry_first_line(line)
{
	delete system_log_match_info
	if (pos = match(line, /^(((((([A-Z][a-z]{2})\s+([0-9]+))\s+(([0-9]{2})[:]([0-9]{2})[:]([0-9]{2})))\s+([^[:space:]]+))\s+(([a-zA-Z]+[a-zA-Z0-9]*)[[]([0-9]+)[]])):)\s*(.*)$/, system_log_match_info)) {
		system_log_entries[syslog_entry_count] = line
		prefix = ""
		for (idx = 0; idx < (length(system_log_match_info) / 3); idx++) {
                    # prefix=system_log_match_info[idx]
                    printf("system_log_match_info[%d] = %s\n", idx, system_log_match_info[idx]) > "/dev/stderr";
                    # prefix = sprintf("%s%s%s", prefix, system_log_match_info[idx], FS)
		}
                print("") > "/dev/stderr"
		printf("is_system_log_entry_first_line %s => prefix: '%s'\n", NR, prefix);
                print("") > "/dev/stderr"
		# system_log_entry_prefixes[syslog_entry_count]=system_log_match_info[]
		return 1
	}
	return 0
}

{
	line = $0
	lines[ln] = line
	delete match_info
	if (is_system_log_entry_first_line(line)) {
